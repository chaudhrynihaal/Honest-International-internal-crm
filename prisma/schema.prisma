// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String    @id @default(cuid())
  name      String
  role      String // "knitter" | "dyer"
  phone     String?
  note      String?
  createdAt DateTime  @default(now())
  entries   Entry[]
  payments  Payment[]
  charges   Charge[]
}

model Entry {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String // "sent" | "received"
  unit      String // "bags" | "kg"
  quantity  Float
  yarnType  String?
  ratePerKg Float?
  note      String?
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([createdAt])
}

model Payment {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@index([contactId])
}

model Charge {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@index([contactId])
}

model FactoryStock {
  id        String   @id @default(cuid())
  yarnType  String
  bags      Float
  rate      Float
  boughtAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([yarnType])
}

model ChecklistItem {
  id        String    @id @default(cuid())
  task      String
  meta      String?
  done      Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
